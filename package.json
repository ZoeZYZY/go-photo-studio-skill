{
  "name": "go-photo-studio-skill",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "skill:validate:example": "node skills/go-photo-studio/scripts/validate_request.cjs --input skills/go-photo-studio/examples/requests/resume-modern.zh.json",
    "skill:compose:example": "node skills/go-photo-studio/scripts/compose_prompt.cjs --input skills/go-photo-studio/examples/requests/resume-modern.zh.json",
    "skill:pipeline:dryrun": "node skills/go-photo-studio/scripts/run-pipeline.cjs --request skills/go-photo-studio/examples/requests/resume-modern.zh.json --provider gemini --outdir .pipeline-out",
    "skill:e2e:mock": "node skills/go-photo-studio/scripts/run-pipeline.cjs --request skills/go-photo-studio/examples/requests/e2e-mock.en.json --provider gemini --outdir .pipeline-out --max-retries 0 --generate-cmd \"node skills/go-photo-studio/scripts/mock-generate.cjs --output \\\"{output}\\\"\"",
    "skill:calibrate": "node skills/go-photo-studio/scripts/calibrate-thresholds.cjs --input skills/go-photo-studio/references/eval/eval.json --output skills/go-photo-studio/references/verification-thresholds.json",
    "skill:test": "node skills/go-photo-studio/tests/smoke.cjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.29.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "heic2any": "^0.0.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
